{
  "name": "team-task-manager",
  "private": true,
  "version": "1.0.0",
  "description": "Team Task Management full-stack app",
  "scripts": {
    "postinstall": "npm run db:generate --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:push": "npm run db:push --workspace=server",
    "db:studio": "npm run db:studio --workspace=server"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
